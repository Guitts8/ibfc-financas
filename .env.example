# Credenciais do Firebase (projeto IBFC Finanças)
#
# COMO OBTER:
# 1. Acesse https://console.firebase.google.com e crie um projeto (ex.: "ibfc-financas").
# 2. Em "Visão geral do projeto" > ícone Web (</>), registre um app web.
# 3. O console mostra um objeto "firebaseConfig" — copie cada valor abaixo.
# 4. Renomeie ESTE arquivo para ".env" (sem ".example") e preencha os valores.
#
# Obs.: estes valores ficam embutidos no app cliente e NÃO são segredos.
# A proteção dos dados vem das Regras de Segurança do Firestore.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
