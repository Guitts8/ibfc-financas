    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.10",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "cross-env __UNSAFE_EXPO_HOME_DIRECTORY=.expo-home expo start",
    "android": "cross-env __UNSAFE_EXPO_HOME_DIRECTORY=.expo-home expo start --android",
    "ios": "cross-env __UNSAFE_EXPO_HOME_DIRECTORY=.expo-home expo start --ios",
    "web": "cross-env __UNSAFE_EXPO_HOME_DIRECTORY=.expo-home expo start --web",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "cross-env __UNSAFE_EXPO_HOME_DIRECTORY=.expo-home expo lint",
    "fb": "cross-env XDG_CONFIG_HOME=.fbconfig npx -y firebase-tools",
    "fb:login": "cross-env XDG_CONFIG_HOME=.fbconfig npx -y firebase-tools login",
    "deploy:rules": "cross-env XDG_CONFIG_HOME=.fbconfig npx -y firebase-tools deploy --only firestore:rules"
  },
  "private": true
